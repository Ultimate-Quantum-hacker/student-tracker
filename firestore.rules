rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function requesterRole() {
      return !isSignedIn()
        ? 'teacher'
        : isDeveloperAccountEmail()
          ? 'developer'
          : exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'head_teacher'
              ? 'head_teacher'
              : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
                ? 'admin'
                : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer'
                  ? 'developer'
                  : 'teacher'
            : 'teacher';
    }

    function requesterEmail() {
      return isSignedIn() && request.auth.token.email != null
        ? request.auth.token.email
        : '';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDeveloperAccountEmail() {
      return requesterEmail() == 'pokumike2@gmail.com';
    }

    function isHeadTeacherRole() {
      return requesterRole() == 'head_teacher';
    }

    function isAdminRole() {
      return requesterRole() == 'admin';
    }

    function isDeveloperRole() {
      return requesterRole() == 'developer';
    }

    function isPrivilegedUser() {
      return isAdminRole() || isDeveloperRole();
    }

    function canReadAllTeacherData() {
      return isHeadTeacherRole() || isAdminRole() || isDeveloperRole();
    }

    function canReadActivityLogsRole() {
      return isHeadTeacherRole() || isAdminRole() || isDeveloperRole();
    }

    function requesterCanSendMessages() {
      return isHeadTeacherRole() || isAdminRole() || isDeveloperRole();
    }

    function requesterCanReplyToMessages() {
      return requesterRole() == 'teacher'
        || isHeadTeacherRole()
        || isAdminRole()
        || isDeveloperRole();
    }

    function requesterCanMessageAudienceType(audienceType) {
      return (audienceType == 'individual' && requesterCanSendMessages())
        || ((audienceType == 'all' || audienceType == 'role' || audienceType == 'class')
          && (isAdminRole() || isDeveloperRole()));
    }

    function requesterCanCreateMessage(audienceType, isReply) {
      return (isReply == true && audienceType == 'individual' && requesterCanReplyToMessages())
        || (isReply != true && requesterCanMessageAudienceType(audienceType));
    }

    function targetUserDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function targetUserCanReceiveMessages(userId) {
      return exists(/databases/$(database)/documents/users/$(userId))
        && (!('status' in targetUserDoc(userId)) || targetUserDoc(userId).status != 'deleted');
    }

    function teacherPermissionsAreCanonical(permissions) {
      return permissions is list
        && permissions.size() == 5
        && permissions.hasAll([
          'read_own_class_data',
          'write_own_class_data',
          'message_individuals',
          'receive_messages',
          'reply_messages'
        ])
        && permissions.hasOnly([
          'read_own_class_data',
          'write_own_class_data',
          'message_individuals',
          'receive_messages',
          'reply_messages'
        ]);
    }

    function headTeacherPermissionsAreCanonical(permissions) {
      return permissions is list
        && permissions.size() == 10
        && permissions.hasAll([
          'read_own_class_data',
          'write_own_class_data',
          'read_all_data',
          'write_all_teacher_data',
          'send_messages',
          'message_individuals',
          'receive_messages',
          'reply_messages',
          'access_admin_panel',
          'read_activity_logs'
        ])
        && permissions.hasOnly([
          'read_own_class_data',
          'write_own_class_data',
          'read_all_data',
          'write_all_teacher_data',
          'send_messages',
          'message_individuals',
          'receive_messages',
          'reply_messages',
          'access_admin_panel',
          'read_activity_logs'
        ]);
    }

    function adminPermissionsAreCanonical(permissions) {
      return permissions is list
        && permissions.size() == 11
        && permissions.hasAll([
          'read_all_data',
          'send_messages',
          'message_all_users',
          'message_roles',
          'message_individuals',
          'message_class_groups',
          'receive_messages',
          'reply_messages',
          'access_admin_panel',
          'review_account_deletion',
          'read_activity_logs'
        ])
        && permissions.hasOnly([
          'read_all_data',
          'send_messages',
          'message_all_users',
          'message_roles',
          'message_individuals',
          'message_class_groups',
          'receive_messages',
          'reply_messages',
          'access_admin_panel',
          'review_account_deletion',
          'read_activity_logs'
        ]);
    }

    function developerPermissionsAreCanonical(permissions) {
      return permissions is list
        && permissions.size() == 20
        && permissions.hasAll([
          'read_own_class_data',
          'write_own_class_data',
          'read_all_data',
          'write_all_teacher_data',
          'send_messages',
          'message_all_users',
          'message_roles',
          'message_individuals',
          'message_class_groups',
          'receive_messages',
          'reply_messages',
          'access_admin_panel',
          'manage_user_roles',
          'manage_system_config',
          'read_activity_logs',
          'clear_activity_logs',
          'delete_registry_students',
          'ghost_mode',
          'read_all_messages',
          'broadcast_messages'
        ])
        && permissions.hasOnly([
          'read_own_class_data',
          'write_own_class_data',
          'read_all_data',
          'write_all_teacher_data',
          'send_messages',
          'message_all_users',
          'message_roles',
          'message_individuals',
          'message_class_groups',
          'receive_messages',
          'reply_messages',
          'access_admin_panel',
          'manage_user_roles',
          'manage_system_config',
          'read_activity_logs',
          'clear_activity_logs',
          'delete_registry_students',
          'ghost_mode',
          'read_all_messages',
          'broadcast_messages'
        ]);
    }

    function permissionsMatchRole(role, permissions) {
      return (role == 'teacher' && teacherPermissionsAreCanonical(permissions))
        || (role == 'head_teacher' && headTeacherPermissionsAreCanonical(permissions))
        || (role == 'admin' && adminPermissionsAreCanonical(permissions))
        || (role == 'developer' && developerPermissionsAreCanonical(permissions));
    }

    function canReadOwnerScopedData(userId) {
      return isOwner(userId) || canReadAllTeacherData();
    }

    function ownerCanCreateOwnUserDoc(userId) {
      return isOwner(userId)
        && request.resource.data.uid == userId
        && (!('userId' in request.resource.data) || request.resource.data.userId == userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'userId',
          'role',
          'permissions',
          'name',
          'email',
          'emailVerified',
          'createdAt',
          'messageUnreadCount',
          'lastMessageAt'
        ])
        && (request.resource.data.role == 'teacher'
          || (isDeveloperAccountEmail() && request.resource.data.role == 'developer'))
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.emailVerified == request.auth.token.email_verified
        && (!('permissions' in request.resource.data)
          || permissionsMatchRole(request.resource.data.role, request.resource.data.permissions))
        && (!('messageUnreadCount' in request.resource.data) || request.resource.data.messageUnreadCount == 0)
        && (!('lastMessageAt' in request.resource.data) || request.resource.data.lastMessageAt == null);
    }

    function ownerRoleUnchangedOrTeacherDefault() {
      return (!('role' in request.resource.data) && !('role' in resource.data))
        || request.resource.data.role == resource.data.role
        || (isDeveloperAccountEmail()
          && request.resource.data.role == 'developer'
          && (!('role' in resource.data)
            || resource.data.role == 'teacher'
            || resource.data.role == 'user'
            || resource.data.role == 'developer'))
        || (!isDeveloperAccountEmail()
          && request.resource.data.role == 'teacher'
          && (!('role' in resource.data)
            || resource.data.role == 'teacher'
            || resource.data.role == 'user'
            || resource.data.role == 'developer'));
    }

    function ownerCanUpdateOwnUserDoc(userId) {
      return isOwner(userId)
        && (!('uid' in request.resource.data) || request.resource.data.uid == userId)
        && (!('userId' in request.resource.data) || request.resource.data.userId == userId)
        && (!('email' in request.resource.data) || request.resource.data.email == request.auth.token.email)
        && (!('emailVerified' in request.resource.data) || request.resource.data.emailVerified == request.auth.token.email_verified)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid',
          'userId',
          'name',
          'email',
          'emailVerified',
          'role',
          'permissions',
          'updatedAt',
          'activeClassId',
          'allowEmptyClassCatalog',
          'messageUnreadCount',
          'lastMessageAt',
          'classMigrationStatus',
          'classMigrationVersion',
          'classMigrationComplete',
          'classMigrationUpdatedAt',
          'classMigrationStartedAt',
          'classMigrationError',
          'classMigrationCountsLegacy',
          'classMigrationCountsClass'
        ])
        && (!('permissions' in request.resource.data)
          || permissionsMatchRole(request.resource.data.role, request.resource.data.permissions))
        && (!('messageUnreadCount' in request.resource.data) || request.resource.data.messageUnreadCount is int)
        && (!('lastMessageAt' in request.resource.data)
          || request.resource.data.lastMessageAt == null
          || request.resource.data.lastMessageAt is string)
        && ownerRoleUnchangedOrTeacherDefault();
    }

    function ownerCanRequestAccountDeletion(userId) {
      return isOwner(userId)
        && (!('uid' in request.resource.data) || request.resource.data.uid == userId)
        && (!('userId' in request.resource.data) || request.resource.data.userId == userId)
        && (!('email' in resource.data) || request.resource.data.email == resource.data.email)
        && (!('emailVerified' in resource.data) || request.resource.data.emailVerified == resource.data.emailVerified)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid',
          'userId',
          'status',
          'accountDeletionStatus',
          'accountDeletionRequestedAt',
          'accountDeletionRequestedBy',
          'accountDeletionReviewedAt',
          'accountDeletionReviewedBy',
          'deletedAt',
          'updatedAt'
        ])
        && request.resource.data.status == 'active'
        && request.resource.data.accountDeletionStatus == 'pending'
        && request.resource.data.accountDeletionRequestedBy == request.auth.uid
        && request.resource.data.accountDeletionRequestedAt is timestamp
        && (!('accountDeletionReviewedAt' in request.resource.data) || request.resource.data.accountDeletionReviewedAt == null)
        && (!('accountDeletionReviewedBy' in request.resource.data) || request.resource.data.accountDeletionReviewedBy == '')
        && (!('deletedAt' in request.resource.data) || request.resource.data.deletedAt == null)
        && ownerRoleUnchangedOrTeacherDefault()
        && (!('accountDeletionStatus' in resource.data) || resource.data.accountDeletionStatus != 'approved')
        && (!('status' in resource.data) || resource.data.status != 'deleted');
    }

    function ownerCanFinalizeApprovedAccountDeletion(userId) {
      return isOwner(userId)
        && (!('uid' in request.resource.data) || request.resource.data.uid == userId)
        && (!('userId' in request.resource.data) || request.resource.data.userId == userId)
        && (!('email' in resource.data) || request.resource.data.email == resource.data.email)
        && (!('emailVerified' in resource.data) || request.resource.data.emailVerified == resource.data.emailVerified)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid',
          'userId',
          'status',
          'deletedAt',
          'updatedAt'
        ])
        && request.resource.data.status == 'deleted'
        && request.resource.data.deletedAt is timestamp
        && resource.data.accountDeletionStatus == 'approved'
        && (!('status' in resource.data) || resource.data.status != 'deleted')
        && ownerRoleUnchangedOrTeacherDefault();
    }

    function privilegedCanReviewAccountDeletion(userId) {
      return isAdminRole()
        && (!('uid' in request.resource.data) || request.resource.data.uid == userId)
        && (!('userId' in request.resource.data) || request.resource.data.userId == userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid',
          'userId',
          'accountDeletionStatus',
          'accountDeletionReviewedAt',
          'accountDeletionReviewedBy',
          'updatedAt'
        ])
        && (!('status' in resource.data) || resource.data.status != 'deleted')
        && resource.data.accountDeletionStatus == 'pending'
        && (
          request.resource.data.accountDeletionStatus == 'approved'
          || request.resource.data.accountDeletionStatus == 'rejected'
        )
        && request.resource.data.accountDeletionReviewedBy == request.auth.uid
        && request.resource.data.accountDeletionReviewedAt is timestamp
        && (!('email' in resource.data) || request.resource.data.email == resource.data.email)
        && (!('emailVerified' in resource.data) || request.resource.data.emailVerified == resource.data.emailVerified)
        && (
          request.resource.data.role == resource.data.role
          || (!('role' in resource.data) && request.resource.data.role == 'teacher')
        );
    }

    function developerCanManageUserRole(userId) {
      return isDeveloperRole()
        && request.resource.data.uid == userId
        && (!('userId' in request.resource.data) || request.resource.data.userId == userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'uid',
          'userId',
          'name',
          'email',
          'emailVerified',
          'role',
          'permissions',
          'updatedAt',
          'roleUpdatedAt',
          'roleUpdatedBy'
        ])
        && (!('email' in resource.data) || request.resource.data.email == resource.data.email)
        && (!('emailVerified' in resource.data) || request.resource.data.emailVerified == resource.data.emailVerified)
        && permissionsMatchRole(request.resource.data.role, request.resource.data.permissions)
        && request.resource.data.roleUpdatedBy == request.auth.uid
        && (
          ((resource.data.role == 'teacher' || resource.data.role == 'user') && (request.resource.data.role == 'teacher' || request.resource.data.role == 'head_teacher' || request.resource.data.role == 'admin'))
          || (resource.data.role == 'head_teacher' && (request.resource.data.role == 'teacher' || request.resource.data.role == 'head_teacher' || request.resource.data.role == 'admin'))
          || (resource.data.role == 'admin' && (request.resource.data.role == 'teacher' || request.resource.data.role == 'head_teacher' || request.resource.data.role == 'admin'))
          || (resource.data.role == 'developer' && request.resource.data.role == 'developer')
        )
        && (
          (request.resource.data.role != 'admin' && request.resource.data.role != 'head_teacher')
          || resource.data.emailVerified == true
        );
    }

    function ownerCanWriteOwnClassDoc(userId, classId) {
      return isOwner(userId)
        && request.resource.data.id == classId
        && request.resource.data.userId == userId
        && request.resource.data.ownerId == userId;
    }

    function isSupportedClassChildCollection(collection) {
      return collection == 'students'
        || collection == 'subjects'
        || collection == 'exams';
    }

    function ownerCanWriteOwnClassChildDoc(userId, classId, docId, collection) {
      return isSupportedClassChildCollection(collection)
        && isOwner(userId)
        && request.resource.data.id == docId
        && request.resource.data.userId == userId
        && request.resource.data.ownerId == userId
        && request.resource.data.classId == classId;
    }

    function isPrivilegedUserMetadataTouch(userId) {
      return isPrivilegedUser()
        && request.resource.data.userId == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId', 'updatedAt']);
    }

    function isPrivilegedClassMetadataTouch(userId, classId) {
      return isPrivilegedUser()
        && request.resource.data.id == classId
        && request.resource.data.userId == userId
        && request.resource.data.ownerId == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['id', 'updatedAt', 'userId', 'ownerId']);
    }

    function isPrivilegedStudentSoftDelete(userId) {
      return isPrivilegedUser()
        && resource.data.deleted != true
        && request.resource.data.deleted == true
        && request.resource.data.userId == userId
        && request.resource.data.ownerId == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted', 'deletedAt', 'updatedAt', 'userId', 'ownerId', 'classId']);
    }

    function senderCanUpdateRecipientMessageMetadata(userId) {
      return isSignedIn()
        && request.auth.uid != userId
        && targetUserCanReceiveMessages(userId)
        && request.resource.data.userId == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'userId',
          'messageUnreadCount',
          'lastMessageAt',
          'updatedAt'
        ])
        && request.resource.data.messageUnreadCount is int
        && request.resource.data.messageUnreadCount >= 1
        && (
          (!('messageUnreadCount' in resource.data) && request.resource.data.messageUnreadCount == 1)
          || (resource.data.messageUnreadCount is int
            && request.resource.data.messageUnreadCount == resource.data.messageUnreadCount + 1)
        )
        && (request.resource.data.lastMessageAt == null || request.resource.data.lastMessageAt is string);
    }

    function messageBaseFieldsAreValid(messageId) {
      return request.resource.data.id == messageId
        && request.resource.data.threadId is string
        && request.resource.data.parentMessageId is string
        && request.resource.data.replyToMessageId is string
        && request.resource.data.isReply is bool
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.senderName is string
        && request.resource.data.senderEmail == requesterEmail()
        && request.resource.data.senderRole == requesterRole()
        && request.resource.data.subject is string
        && request.resource.data.body is string
        && request.resource.data.bodyPreview is string
        && (request.resource.data.audienceType == 'all'
          || request.resource.data.audienceType == 'role'
          || request.resource.data.audienceType == 'individual'
          || request.resource.data.audienceType == 'class')
        && request.resource.data.audienceRole is string
        && request.resource.data.audienceClassId is string
        && request.resource.data.audienceClassName is string
        && request.resource.data.audienceLabel is string
        && request.resource.data.recipientCount is int
        && request.resource.data.recipientCount >= 1
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.sentAt is timestamp;
    }

    function ownerCanCreateSentMessage(userId, messageId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'id',
          'mailbox',
          'threadId',
          'parentMessageId',
          'replyToMessageId',
          'isReply',
          'senderId',
          'senderName',
          'senderEmail',
          'senderRole',
          'subject',
          'body',
          'bodyPreview',
          'audienceType',
          'audienceRole',
          'audienceClassId',
          'audienceClassName',
          'audienceLabel',
          'recipientCount',
          'sentAt',
          'createdAt',
          'updatedAt',
          'recipientUserId',
          'recipientName',
          'recipientEmail',
          'recipientRole',
          'recipientUserIds',
          'recipientLabel',
          'isRead',
          'readAt'
        ])
        && request.resource.data.mailbox == 'sent'
        && messageBaseFieldsAreValid(messageId)
        && request.resource.data.recipientUserId is string
        && request.resource.data.recipientName is string
        && request.resource.data.recipientEmail is string
        && request.resource.data.recipientRole is string
        && request.resource.data.recipientUserIds is list
        && request.resource.data.recipientLabel is string
        && request.resource.data.isRead == true
        && request.resource.data.readAt is timestamp
        && requesterCanCreateMessage(request.resource.data.audienceType, request.resource.data.isReply);
    }

    function senderCanCreateInboxMessage(userId, messageId) {
      return isSignedIn()
        && request.auth.uid != userId
        && targetUserCanReceiveMessages(userId)
        && request.resource.data.keys().hasOnly([
          'id',
          'mailbox',
          'threadId',
          'parentMessageId',
          'replyToMessageId',
          'isReply',
          'senderId',
          'senderName',
          'senderEmail',
          'senderRole',
          'subject',
          'body',
          'bodyPreview',
          'audienceType',
          'audienceRole',
          'audienceClassId',
          'audienceClassName',
          'audienceLabel',
          'recipientCount',
          'sentAt',
          'createdAt',
          'updatedAt',
          'recipientUserId',
          'recipientName',
          'recipientEmail',
          'recipientRole',
          'recipientUserIds',
          'recipientLabel',
          'fromSentMessageId',
          'isRead',
          'readAt'
        ])
        && request.resource.data.mailbox == 'inbox'
        && messageBaseFieldsAreValid(messageId)
        && request.resource.data.recipientUserId == userId
        && request.resource.data.recipientName is string
        && request.resource.data.recipientEmail is string
        && request.resource.data.recipientRole is string
        && request.resource.data.recipientUserIds is list
        && request.resource.data.recipientUserIds.size() == 1
        && request.resource.data.recipientLabel is string
        && request.resource.data.fromSentMessageId is string
        && request.resource.data.isRead == false
        && request.resource.data.readAt == null
        && requesterCanCreateMessage(request.resource.data.audienceType, request.resource.data.isReply);
    }

    function ownerCanToggleMessageReadState(userId) {
      return isOwner(userId)
        && resource.data.mailbox == 'inbox'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'isRead',
          'readAt',
          'updatedAt'
        ])
        && (
          (request.resource.data.isRead == true && request.resource.data.readAt is timestamp)
          || (request.resource.data.isRead == false && request.resource.data.readAt == null)
        )
        && request.resource.data.updatedAt is string;
    }

    function requesterCanStartConversations() {
      return requesterRole() == 'teacher'
        || isHeadTeacherRole()
        || isAdminRole()
        || isDeveloperRole();
    }

    function requesterCanStartConversationWithRole(targetRole) {
      return (requesterRole() == 'teacher' && targetRole == 'admin')
        || (requesterRole() == 'head_teacher' && (targetRole == 'teacher' || targetRole == 'admin'))
        || (requesterRole() == 'admin' && (targetRole == 'teacher' || targetRole == 'head_teacher' || targetRole == 'admin'))
        || (requesterRole() == 'developer' && (targetRole == 'teacher' || targetRole == 'head_teacher' || targetRole == 'admin' || targetRole == 'developer'));
    }

    function conversationHasParticipant(conversationData, userId) {
      return conversationData.participants is list
        && userId in conversationData.participants;
    }

    // Unified helper: reusable across read, write, and subcollection rules
    function isParticipantOrDeveloper(conversationData) {
      return request.auth != null
        && (
          conversationHasParticipant(conversationData, request.auth.uid)
          || isDeveloperRole()
        );
    }

    function requesterCanReadConversationData(conversationData) {
      return isSignedIn()
        && conversationHasParticipant(conversationData, request.auth.uid);
    }

    function requesterCanReadConversation(conversationId) {
      return exists(/databases/$(database)/documents/conversations/$(conversationId))
        && requesterCanReadConversationData(get(/databases/$(database)/documents/conversations/$(conversationId)).data);
    }

    function requestConversationCounterpartId() {
      return request.resource.data.participants[0] == request.auth.uid
        ? request.resource.data.participants[1]
        : request.resource.data.participants[0];
    }

    function resourceConversationCounterpartId() {
      return resource.data.participants[0] == request.auth.uid
        ? resource.data.participants[1]
        : resource.data.participants[0];
    }

    function conversationBaseFieldsAreValid(conversationId) {
      return request.resource.data.id == conversationId
        && (request.resource.data.type == 'direct'
          || request.resource.data.type == 'role'
          || request.resource.data.type == 'broadcast')
        && request.resource.data.directKey is string
        && request.resource.data.directKey != ''
        && request.resource.data.participants is list
        && request.resource.data.participants.size() >= 2
        && request.resource.data.participants[0] is string
        && request.resource.data.participants[1] is string
        && request.resource.data.participants[0] != request.resource.data.participants[1]
        && conversationHasParticipant(request.resource.data, request.auth.uid)
        && request.resource.data.participantNames is map
        && request.resource.data.participantEmails is map
        && request.resource.data.participantRoles is map
        && request.resource.data.initiatorId is string
        && request.resource.data.initiatorRole is string
        && request.resource.data.lastMessageText is string
        && request.resource.data.lastMessagePreview is string
        && request.resource.data.lastMessageAt is string
        && request.resource.data.lastMessageSenderId is string
        && request.resource.data.lastMessageSenderName is string
        && request.resource.data.lastMessageSenderRole is string
        && request.resource.data.unreadCountByUser is map
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function requesterCanCreateConversation(conversationId) {
      return isSignedIn()
        && requesterCanStartConversations()
        && conversationBaseFieldsAreValid(conversationId)
        && request.resource.data.initiatorId == request.auth.uid
        && request.resource.data.initiatorRole == requesterRole()
        && request.resource.data.lastMessageSenderId == request.auth.uid
        && request.resource.data.lastMessageSenderRole == requesterRole()
        && request.resource.data.participantRoles[request.auth.uid] == requesterRole()
        && targetUserCanReceiveMessages(requestConversationCounterpartId())
        && requesterCanStartConversationWithRole(targetUserDoc(requestConversationCounterpartId()).role)
        && request.resource.data.participantRoles[requestConversationCounterpartId()] == targetUserDoc(requestConversationCounterpartId()).role
        && request.resource.data.unreadCountByUser[request.auth.uid] == 0
        && request.resource.data.unreadCountByUser[requestConversationCounterpartId()] == 1;
    }

    function requesterCanApplyConversationSendUpdate() {
      return request.resource.data.lastMessageSenderId == request.auth.uid
        && request.resource.data.lastMessageSenderRole == requesterRole()
        && request.resource.data.unreadCountByUser[request.auth.uid] == 0
        && resource.data.unreadCountByUser[resourceConversationCounterpartId()] is int
        && request.resource.data.unreadCountByUser[resourceConversationCounterpartId()] is int
        && request.resource.data.unreadCountByUser[resourceConversationCounterpartId()] == resource.data.unreadCountByUser[resourceConversationCounterpartId()] + 1;
    }

    function requesterCanApplyConversationReadUpdate() {
      return request.resource.data.lastMessageText == resource.data.lastMessageText
        && request.resource.data.lastMessagePreview == resource.data.lastMessagePreview
        && request.resource.data.lastMessageAt == resource.data.lastMessageAt
        && request.resource.data.lastMessageSenderId == resource.data.lastMessageSenderId
        && request.resource.data.lastMessageSenderName == resource.data.lastMessageSenderName
        && request.resource.data.lastMessageSenderRole == resource.data.lastMessageSenderRole
        && request.resource.data.unreadCountByUser[request.auth.uid] == 0
        && request.resource.data.unreadCountByUser[resourceConversationCounterpartId()] == resource.data.unreadCountByUser[resourceConversationCounterpartId()];
    }

    function requesterCanUpdateConversation(conversationId) {
      return isSignedIn()
        && requesterCanReadConversationData(resource.data)
        && conversationHasParticipant(resource.data, request.auth.uid)
        && request.resource.data.id == conversationId
        && request.resource.data.type == resource.data.type
        && request.resource.data.directKey == resource.data.directKey
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.participantRoles == resource.data.participantRoles
        && request.resource.data.initiatorId == resource.data.initiatorId
        && request.resource.data.initiatorRole == resource.data.initiatorRole
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'participantNames',
          'participantEmails',
          'lastMessageText',
          'lastMessagePreview',
          'lastMessageAt',
          'lastMessageSenderId',
          'lastMessageSenderName',
          'lastMessageSenderRole',
          'unreadCountByUser',
          'updatedAt',
          'senderVisibility',
          'senderDisplayName'
        ])
        && (
          requesterCanApplyConversationSendUpdate()
          || requesterCanApplyConversationReadUpdate()
        );
    }

    function conversationMessageBaseFieldsAreValid(conversationId, messageId) {
      return request.resource.data.id == messageId
        && request.resource.data.conversationId == conversationId
        && request.resource.data.type == 'text'
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.senderName is string
        && request.resource.data.senderEmail == requesterEmail()
        && request.resource.data.senderRole == requesterRole()
        && request.resource.data.text is string
        && request.resource.data.body is string
        && request.resource.data.readByUserIds is list
        && request.resource.data.readByUserIds.size() == 1
        && request.resource.data.readByUserIds[0] == request.auth.uid
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string
        && request.resource.data.sentAt is timestamp;
    }

    function requesterCanCreateConversationMessage(conversationId, messageId) {
      return existsAfter(/databases/$(database)/documents/conversations/$(conversationId))
        && requesterCanReadConversationData(getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data)
        && conversationMessageBaseFieldsAreValid(conversationId, messageId)
        && getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.lastMessageSenderId == request.auth.uid
        && getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data.lastMessageText == request.resource.data.text;
    }

    function requesterCanUpdateConversationMessage(conversationId, messageId) {
      return requesterCanReadConversation(conversationId)
        && request.resource.data.id == messageId
        && request.resource.data.conversationId == resource.data.conversationId
        && request.resource.data.type == resource.data.type
        && request.resource.data.senderId == resource.data.senderId
        && request.resource.data.senderName == resource.data.senderName
        && request.resource.data.senderEmail == resource.data.senderEmail
        && request.resource.data.senderRole == resource.data.senderRole
        && request.resource.data.text == resource.data.text
        && request.resource.data.body == resource.data.body
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.sentAt == resource.data.sentAt
        && request.resource.data.updatedAt is string
        && request.resource.data.readByUserIds is list
        && request.resource.data.readByUserIds.hasAll(resource.data.readByUserIds)
        && request.resource.data.readByUserIds.hasAll([request.auth.uid])
        && request.resource.data.readByUserIds.size() <= resource.data.readByUserIds.size() + 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'readByUserIds',
          'updatedAt'
        ]);
    }

    match /users/{userId} {
      allow read: if canReadOwnerScopedData(userId);
      allow create: if ownerCanCreateOwnUserDoc(userId);
      allow delete: if isOwner(userId) || isDeveloperRole();
      allow update: if ownerCanUpdateOwnUserDoc(userId)
        || ownerCanRequestAccountDeletion(userId)
        || ownerCanFinalizeApprovedAccountDeletion(userId)
        || developerCanManageUserRole(userId)
        || privilegedCanReviewAccountDeletion(userId)
        || isPrivilegedUserMetadataTouch(userId)
        || senderCanUpdateRecipientMessageMetadata(userId);
    }

    match /users/{userId}/messages/{messageId} {
      allow read: if isOwner(userId);
      allow create: if ownerCanCreateSentMessage(userId, messageId)
        || senderCanCreateInboxMessage(userId, messageId);
      allow update: if ownerCanToggleMessageReadState(userId);
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      // READ: participant can read; developer gets bypass on get only
      allow get: if requesterCanReadConversationData(resource.data)
        || isDeveloperRole();
      // LIST: no type check — Firestore list evaluator can't verify 'is list' from array-contains
      // The 'in' operator on a non-list field returns false, so security is maintained
      allow list: if request.auth != null
        && request.auth.uid in resource.data.participants;
      // CREATE: creator must be in participants[] + valid fields; developer bypass still requires membership
      allow create: if requesterCanCreateConversation(conversationId)
        || (isDeveloperRole()
          && request.resource.data.participants is list
          && request.auth.uid in request.resource.data.participants);
      // UPDATE: participants[] FROZEN — cannot be modified by anyone (including developer)
      allow update: if requesterCanUpdateConversation(conversationId)
        || (isDeveloperRole()
          && request.resource.data.participants == resource.data.participants);
      // DELETE: permanently blocked
      allow delete: if false;

      match /messages/{messageId} {
        // READ: participant in parent conversation OR developer
        allow read: if requesterCanReadConversation(conversationId)
          || isDeveloperRole();
        // CREATE: senderId MUST equal auth.uid — no spoofing; developer bypass still enforces this
        allow create: if requesterCanCreateConversationMessage(conversationId, messageId)
          || (isDeveloperRole()
            && request.resource.data.senderId == request.auth.uid
            && isParticipantOrDeveloper(
              getAfter(/databases/$(database)/documents/conversations/$(conversationId)).data
            ));
        // UPDATE: only readByUserIds + updatedAt can change; developer has full update access
        allow update: if requesterCanUpdateConversationMessage(conversationId, messageId)
          || isDeveloperRole();
        // DELETE: permanently blocked
        allow delete: if false;
      }
    }

    match /users/{userId}/classes/{classId} {
      allow read: if canReadOwnerScopedData(userId);
      allow create: if ownerCanWriteOwnClassDoc(userId, classId) || isDeveloperRole();
      allow delete: if isOwner(userId) || isDeveloperRole();
      allow update: if ownerCanWriteOwnClassDoc(userId, classId) || isDeveloperRole() || isPrivilegedClassMetadataTouch(userId, classId);
    }

    match /users/{userId}/classes/{classId}/{collection}/{docId} {
      allow read: if isSupportedClassChildCollection(collection) && canReadOwnerScopedData(userId);
      allow create: if ownerCanWriteOwnClassChildDoc(userId, classId, docId, collection) || isDeveloperRole();
      allow delete: if isSupportedClassChildCollection(collection) && (isOwner(userId) || isDeveloperRole());
      allow update: if ownerCanWriteOwnClassChildDoc(userId, classId, docId, collection)
        || isDeveloperRole()
        || (collection == 'students'
          && request.resource.data.classId == classId
          && isPrivilegedStudentSoftDelete(userId));
    }

    match /users/{userId}/students/{docId} {
      allow read: if canReadOwnerScopedData(userId);
      allow create, delete: if isOwner(userId) || isDeveloperRole();
      allow update: if isOwner(userId) || isDeveloperRole() || isPrivilegedStudentSoftDelete(userId);
    }

    match /users/{userId}/subjects/{docId} {
      allow read: if canReadOwnerScopedData(userId);
      allow write: if isOwner(userId) || isDeveloperRole();
    }

    match /users/{userId}/exams/{docId} {
      allow read: if canReadOwnerScopedData(userId);
      allow write: if isOwner(userId) || isDeveloperRole();
    }

    match /{path=**}/students/{docId} {
      allow read: if canReadAllTeacherData();
    }

    match /{path=**}/subjects/{docId} {
      allow read: if canReadAllTeacherData();
    }

    match /{path=**}/exams/{docId} {
      allow read: if canReadAllTeacherData();
    }

    match /{path=**}/classes/{classId} {
      allow read: if canReadAllTeacherData();
    }

    match /activityLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if canReadActivityLogsRole();
      allow delete: if isDeveloperRole();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
