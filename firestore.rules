rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function requesterRole() {
      return !isSignedIn()
        ? 'teacher'
        : (!exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? 'teacher'
            : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role);
    }

    function requesterAccountStatus() {
      return !isSignedIn()
        ? 'deleted'
        : (!exists(/databases/$(database)/documents/users/$(request.auth.uid))
            ? 'active'
            : (
                get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountStatus == 'suspended'
                  ? 'suspended'
                  : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountStatus == 'deleted'
                    ? 'deleted'
                    : 'active'
              ));
    }

    function isRequesterActive() {
      return isSignedIn() && requesterAccountStatus() == 'active';
    }

    function isRequesterAdmin() {
      return isRequesterActive() && requesterRole() == 'admin';
    }

    function isRequesterDeveloper() {
      return isRequesterActive() && requesterRole() == 'developer';
    }

    function canReadManagedUserData(userId) {
      return isOwner(userId) || isRequesterAdmin() || isRequesterDeveloper();
    }

    function isProtectedDeveloperTarget() {
      return resource.data.role == 'developer' || resource.data.email == 'pokumike2@gmail.com';
    }

    function isAdminManagedStatusUpdate() {
      return request.resource.data.uid == resource.data.uid
        && request.resource.data.name == resource.data.name
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && (
          request.resource.data.accountStatus == 'active'
          || request.resource.data.accountStatus == 'suspended'
          || (request.resource.data.accountStatus == 'deleted' && resource.data.role == 'teacher')
        );
    }

    match /users/{userId} {
      allow read: if canReadManagedUserData(userId);
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && isRequesterActive())
        || isRequesterDeveloper()
        || (isRequesterAdmin() && !isProtectedDeveloperTarget() && isAdminManagedStatusUpdate());
    }

    match /users/{userId}/classes/{classId} {
      allow read: if canReadManagedUserData(userId);
      allow write: if isOwner(userId) && isRequesterActive();
    }

    match /users/{userId}/classes/{classId}/{collection}/{docId} {
      allow read: if canReadManagedUserData(userId);
      allow write: if isOwner(userId) && isRequesterActive();
    }

    match /users/{userId}/students/{docId} {
      allow read: if canReadManagedUserData(userId);
    }

    match /users/{userId}/subjects/{docId} {
      allow read: if canReadManagedUserData(userId);
    }

    match /users/{userId}/exams/{docId} {
      allow read: if canReadManagedUserData(userId);
    }

    match /{path=**}/classes/{classId} {
      allow read: if isRequesterActive();
    }

    match /activityLogs/{logId} {
      allow create, read: if isRequesterActive();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
