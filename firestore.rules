rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDeveloperEmail() {
      return isAuthenticated()
        && request.auth.token.email is string
        && request.auth.token.email.matches('^[Pp][Oo][Kk][Uu][Mm][Ii][Kk][Ee]2@gmail\\.com$');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAllowedRole(role) {
      return role in ['teacher', 'admin', 'developer', 'user'];
    }

    function requesterRole() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'teacher';
    }

    function isAdminRole() {
      return requesterRole() == 'admin';
    }

    function isDeveloperRole() {
      return isDeveloperEmail() || requesterRole() == 'developer';
    }

    function isAdminOrDeveloperRole() {
      return isAdminRole() || isDeveloperRole();
    }

    function hasValidUserProfileShape(userId) {
      return (!('uid' in request.resource.data)
          || (
            request.resource.data.uid is string
            && request.resource.data.uid == userId
          ))
        && (!('name' in request.resource.data) || request.resource.data.name is string)
        && (!('email' in request.resource.data) || request.resource.data.email is string)
        && (!('role' in request.resource.data) || isAllowedRole(request.resource.data.role))
        && (!('activeClassId' in request.resource.data) || request.resource.data.activeClassId is string)
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is string)
        && (!('classMigrationStatus' in request.resource.data) || request.resource.data.classMigrationStatus is string)
        && (!('classMigrationVersion' in request.resource.data) || request.resource.data.classMigrationVersion is int)
        && (!('classMigrationComplete' in request.resource.data) || request.resource.data.classMigrationComplete is bool)
        && (!('classMigrationStartedAt' in request.resource.data) || request.resource.data.classMigrationStartedAt is string)
        && (!('classMigrationUpdatedAt' in request.resource.data) || request.resource.data.classMigrationUpdatedAt is string)
        && (!('classMigrationCompletedAt' in request.resource.data) || request.resource.data.classMigrationCompletedAt is string)
        && (!('classMigrationError' in request.resource.data) || request.resource.data.classMigrationError is string);
    }

    function hasValidClassDoc(userId, classId) {
      return request.resource.data.id is string
        && request.resource.data.id == classId
        && request.resource.data.ownerId is string
        && request.resource.data.ownerId == userId
        && request.resource.data.userId is string
        && request.resource.data.userId == userId
        && (!('name' in request.resource.data) || request.resource.data.name is string)
        && (!('ownerName' in request.resource.data) || request.resource.data.ownerName is string);
    }

    function hasValidClassScopedDoc(userId, classId) {
      return request.resource.data.classId is string
        && request.resource.data.classId == classId
        && request.resource.data.ownerId is string
        && request.resource.data.ownerId == userId
        && request.resource.data.userId is string
        && request.resource.data.userId == userId;
    }

    function canWriteScopedOwnerPath(userId) {
      return (isOwner(userId) || isDeveloperRole())
        && !isAdminRole();
    }

    function hasValidActivityLogV2Shape() {
      return request.resource.data.userId is string
        && request.resource.data.userEmail is string
        && request.resource.data.userRole is string
        && isAllowedRole(request.resource.data.userRole)
        && request.resource.data.action is string
        && request.resource.data.targetType is string
        && request.resource.data.targetId is string
        && request.resource.data.classId is string
        && request.resource.data.className is string
        && request.resource.data.ownerId is string
        && request.resource.data.ownerName is string
        && request.resource.data.dataOwnerUserId is string
        && request.resource.data.logVersion is int
        && request.resource.data.logVersion == 2;
    }

    function isRoleUpdateByOwnerAllowed() {
      return request.resource.data.role == resource.data.role
        || (
          resource.data.role == 'user'
          && request.resource.data.role == 'teacher'
        )
        || (
          !('role' in resource.data)
          && request.resource.data.role == 'teacher'
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();

      allow write: if isDeveloperRole();

      allow create: if isOwner(userId)
        && hasValidUserProfileShape(userId)
        && (
          (isDeveloperEmail() && request.resource.data.role == 'developer')
          || (!isDeveloperEmail() && request.resource.data.role == 'teacher')
        );

      allow update: if isOwner(userId)
        && hasValidUserProfileShape(userId)
        && isRoleUpdateByOwnerAllowed();
    }

    match /users/{userId}/classes/{classId} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();
      allow create, update: if canWriteScopedOwnerPath(userId)
        && hasValidClassDoc(userId, classId);
      allow delete: if canWriteScopedOwnerPath(userId);
    }

    match /users/{userId}/classes/{classId}/students/{docId} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();
      allow create, update: if canWriteScopedOwnerPath(userId)
        && hasValidClassScopedDoc(userId, classId);
      allow delete: if canWriteScopedOwnerPath(userId);
    }

    match /users/{userId}/classes/{classId}/subjects/{docId} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();
      allow create, update: if canWriteScopedOwnerPath(userId)
        && hasValidClassScopedDoc(userId, classId);
      allow delete: if canWriteScopedOwnerPath(userId);
    }

    match /users/{userId}/classes/{classId}/exams/{docId} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();
      allow create, update: if canWriteScopedOwnerPath(userId)
        && hasValidClassScopedDoc(userId, classId);
      allow delete: if canWriteScopedOwnerPath(userId);
    }

    match /users/{userId}/students/{docId} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();
      allow write: if isDeveloperRole();
    }

    match /users/{userId}/subjects/{docId} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();
      allow write: if isDeveloperRole();
    }

    match /users/{userId}/exams/{docId} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();
      allow write: if isDeveloperRole();
    }

    match /{path=**}/students/{docId} {
      allow read: if isAuthenticated()
        && (
          isAdminOrDeveloperRole()
          || request.auth.uid == resource.data.ownerId
          || request.auth.uid == resource.data.userId
        );
    }

    match /activityLogs/{logId} {
      allow create: if isAuthenticated() && hasValidActivityLogV2Shape();
      allow read: if isAdminOrDeveloperRole();
      allow update, delete: if isDeveloperRole();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
