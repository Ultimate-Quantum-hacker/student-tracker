rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDeveloperEmail() {
      return isAuthenticated() && request.auth.token.email == 'pokumike2@gmail.com';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isDeveloper() {
      return isAuthenticated() && getUserRole() == 'developer';
    }

    function canAccessUserData(userId) {
      return isOwner(userId) || isAdmin() || isDeveloper();
    }

    function isValidRole(role) {
      return role in ['user', 'teacher', 'admin', 'developer'];
    }

    function hasValidUserProfileShape(userId) {
      return request.resource.data.keys().hasOnly(['uid', 'role', 'name', 'email', 'createdAt'])
        && request.resource.data.uid is string
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.email is string
        && isValidRole(request.resource.data.role);
    }

    function isRoleUpdateByOwnerAllowed() {
      return request.resource.data.role == resource.data.role
        || (
          !('role' in resource.data)
          && (request.resource.data.role == 'user' || request.resource.data.role == 'teacher')
        );
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && hasValidUserProfileShape(userId)
        && (
          (isDeveloperEmail() && request.resource.data.role == 'developer')
          || (!isDeveloperEmail() && (request.resource.data.role == 'user' || request.resource.data.role == 'teacher'))
        );

      allow read: if canAccessUserData(userId);

      allow update: if (
          isOwner(userId)
          && hasValidUserProfileShape(userId)
          && isRoleUpdateByOwnerAllowed()
          && request.resource.data.createdAt == resource.data.createdAt
        )
        || (
          isAdmin()
          && hasValidUserProfileShape(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.createdAt == resource.data.createdAt
        )
        || (
          isDeveloper()
          && hasValidUserProfileShape(userId)
          && request.resource.data.createdAt == resource.data.createdAt
        );

      allow delete: if isDeveloper();

      match /classes/{classId} {
        allow read, write: if canAccessUserData(userId);

        match /{document=**} {
          allow read, write: if canAccessUserData(userId);
        }
      }
    }

    match /devTools/{document=**} {
      allow read, write: if isDeveloper();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
