rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDeveloperEmail() {
      return isAuthenticated()
        && request.auth.token.email is string
        && request.auth.token.email.matches('^[Pp][Oo][Kk][Uu][Mm][Ii][Kk][Ee]2@gmail\\.com$');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasValidUserProfileShape(userId) {
      return request.resource.data.keys().hasOnly(['uid', 'role', 'name', 'email', 'createdAt'])
        && request.resource.data.uid is string
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.role in ['teacher', 'admin', 'developer'];
    }

    function isRoleUpdateByOwnerAllowed() {
      return request.resource.data.role == resource.data.role
        || (
          resource.data.role == 'user'
          && request.resource.data.role == 'teacher'
        )
        || (
          !('role' in resource.data)
          && request.resource.data.role == 'teacher'
        );
    }

    match /users/{userId} {
      allow read: if isAuthenticated();

      allow write: if isAuthenticated() && isDeveloperEmail();

      allow create: if isOwner(userId)
        && hasValidUserProfileShape(userId)
        && (
          (isDeveloperEmail() && request.resource.data.role == 'developer')
          || (!isDeveloperEmail() && request.resource.data.role == 'teacher')
        );

      allow update: if isOwner(userId)
        && hasValidUserProfileShape(userId)
        && isRoleUpdateByOwnerAllowed();
    }

    match /users/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
