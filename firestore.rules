rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /users/{userId}/classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /users/{userId}/classes/{classId}/{collection}/{docId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /users/{userId}/students/{docId} {
      allow read: if isSignedIn();
    }

    match /users/{userId}/subjects/{docId} {
      allow read: if isSignedIn();
    }

    match /users/{userId}/exams/{docId} {
      allow read: if isSignedIn();
    }

    match /{path=**}/classes/{classId} {
      allow read: if isSignedIn();
    }

    match /activityLogs/{logId} {
      allow create, read: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
