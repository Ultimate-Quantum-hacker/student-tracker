rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDeveloperEmail() {
      return isAuthenticated()
        && request.auth.token.email is string
        && request.auth.token.email.matches('^[Pp][Oo][Kk][Uu][Mm][Ii][Kk][Ee]2@gmail\\.com$');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function requesterRole() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'teacher';
    }

    function isAdminRole() {
      return requesterRole() == 'admin';
    }

    function isDeveloperRole() {
      return isDeveloperEmail() || requesterRole() == 'developer';
    }

    function isAdminOrDeveloperRole() {
      return isAdminRole() || isDeveloperRole();
    }

    function hasValidUserProfileShape(userId) {
      return request.resource.data.keys().hasOnly(['uid', 'role', 'name', 'email', 'createdAt'])
        && request.resource.data.uid is string
        && request.resource.data.uid == userId
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.role in ['teacher', 'admin', 'developer'];
    }

    function isRoleUpdateByOwnerAllowed() {
      return request.resource.data.role == resource.data.role
        || (
          resource.data.role == 'user'
          && request.resource.data.role == 'teacher'
        )
        || (
          !('role' in resource.data)
          && request.resource.data.role == 'teacher'
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();

      allow write: if isDeveloperRole();

      allow create: if isOwner(userId)
        && hasValidUserProfileShape(userId)
        && (
          (isDeveloperEmail() && request.resource.data.role == 'developer')
          || (!isDeveloperEmail() && request.resource.data.role == 'teacher')
        );

      allow update: if isOwner(userId)
        && hasValidUserProfileShape(userId)
        && isRoleUpdateByOwnerAllowed();
    }

    match /users/{userId}/{document=**} {
      allow read: if isOwner(userId) || isAdminOrDeveloperRole();
      allow write: if isOwner(userId) || isDeveloperRole();
    }

    match /{path=**}/students/{docId} {
      allow read: if isAuthenticated()
        && (
          request.auth.uid == resource.data.userId
          || isAdminOrDeveloperRole()
        );
    }

    match /activityLogs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdminOrDeveloperRole();
      allow update, delete: if isDeveloperRole();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
